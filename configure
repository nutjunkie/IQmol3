#! /bin/bash

TOPDIR=$( cd -- "$( dirname -- "${BASH_SOURCE[0]}" )" &> /dev/null && pwd )
mkdir -p $TOPDIR/build

CONFIGURE_ARGS="$*"
WITH_OPENMP=auto
BUILD_TYPE=Debug
declare -a CMAKE_ARGS

for arg in "$@"; do
   case "$arg" in
      --debug)
         BUILD_TYPE=Debug
         ;;
      --release)
         BUILD_TYPE=Release
         ;;
      --with-openmp)
         WITH_OPENMP=yes
         ;;
      --without-openmp)
         WITH_OPENMP=no
         ;;
      *)
         CMAKE_ARGS+=("$arg")
         ;;
   esac
done

echo "IQmol configured by `whoami`@`hostname`:" > configure.log
date >> configure.log
echo "" >> configure.log
echo "$0 $CONFIGURE_ARGS" >> configure.log
echo "CXX set to $CXX" >> configure.log
echo "BUILD_TYPE=$BUILD_TYPE" >> configure.log
echo "WITH_OPENMP=$WITH_OPENMP" >> configure.log
echo "" >> configure.log

ARCH=$(uname)
echo "Configuring build for $ARCH" >> configure.log

DEFINES="-DBUILD_SHARED=OFF -DQARCHIVE=OFF"


if [ $ARCH == 'Darwin' ]; then
   CMAKE_GENERATOR="Unix Makefiles"
   QT=/opt/homebrew/Cellar/qt@5/5.15.13_1
   #QT=/opt/homebrew/Cellar/qt@5/5.15.8_2
   #DEFINES+=" -DCMAKE_CXX_FLAGS=-arch x86_64"

elif [ $ARCH == 'Linux' ]; then
   CMAKE_GENERATOR="Unix Makefiles"
   QT=/scratch/software_test/Qt5/5.12.12/gcc_64
   QT=/usr/lib/x86_64-linux-gnu/qt5/
   DEFINES+=" -DYAML_BUILD_SHARED_LIBS=OFF"

else 
   ARCH='Windoze'
   CMAKE_GENERATOR="MinGW Makefiles"
   QT=C:/Qt/Qt5.12.12/5.12.12/mingw73_64
   MINGW_ROOT=C:/mingw64
   TOPDIR=${TOPDIR/\/cygdrive\/c/C:}

   DEFINES+=" -DQT_UIC_EXECUTABLE=${QT}/bin/uic.exe"
   DEFINES+=" -DCMAKE_C_COMPILER=${MINGW_ROOT}/bin/x86_64-w64-mingw32-gcc.exe"
   DEFINES+=" -DCMAKE_CXX_COMPILER=${MINGW_ROOT}/bin/x86_64-w64-mingw32-g++.exe"
   DEFINES+=" -DCMAKE_Fortran_COMPILER=${MINGW_ROOT}/bin/x86_64-w64-mingw32-gfortran.exe"
   DEFINES+=" -DZLIB_INCLUDE_DIR=${MINGW_ROOT}/x86_64-w64-mingw32/include"
   DEFINES+=" -DZLIB_LIBRARY=${MINGW_ROOT}/x86_64-w64-mingw32/lib/libz.a"
   DEFINES+=" -DBOOST_ROOT=C:/boost"
   DEFINES+=" -DHDF5_ROOT=C:/Users/andre/Development/hdf5"
   DEFINES+=" -DOPENSSL_ROOT_DIR=${TOPDIR}/modules/openssl"
fi


if [ -z ${CMAKE_PREFIX_PATH+x} ]; then 
   CMAKE_PREFIX=${QT}/lib/cmake/Qt5
else 
   CMAKE_PREFIX=${CMAKE_PREFIX_PATH}
fi

if [ "$WITH_OPENMP" != "no" ] && [ $ARCH == 'Darwin' ]; then
   if [ -d /opt/homebrew/opt/libomp ]; then
      CMAKE_PREFIX="${CMAKE_PREFIX};/opt/homebrew/opt/libomp"
      DEFINES+=" -DOpenMP_ROOT=/opt/homebrew/opt/libomp"
   elif [ -d /usr/local/opt/libomp ]; then
      CMAKE_PREFIX="${CMAKE_PREFIX};/usr/local/opt/libomp"
      DEFINES+=" -DOpenMP_ROOT=/usr/local/opt/libomp"
   fi
fi

if [ "$WITH_OPENMP" == "no" ]; then
   DEFINES+=" -DCMAKE_DISABLE_FIND_PACKAGE_OpenMP=TRUE"
fi

DEFINES+=" -DCMAKE_PREFIX_PATH=${CMAKE_PREFIX}"
DEFINES+=" -DCMAKE_BUILD_TYPE=${BUILD_TYPE}"

echo "QT root = $QT" >> configure.log
echo "CMAKE_PREFIX_PATH = $CMAKE_PREFIX" >> configure.log
echo "DEFINES = $DEFINES" >> configure.log

cd $TOPDIR/build

if [ -e CMakeCache.txt ]; then
    rm CMakeCache.txt
fi

cmake -G "$CMAKE_GENERATOR" $DEFINES "${CMAKE_ARGS[@]}" $TOPDIR 2>&1 | tee -a ../configure.log
CMAKE_STATUS=${PIPESTATUS[0]}

if [ $CMAKE_STATUS -ne 0 ]; then
   exit $CMAKE_STATUS
fi

OPENMP_FOUND=no
if [ -e CMakeCache.txt ]; then
   OPENMP_FLAGS=$(grep '^OpenMP_CXX_FLAGS:STRING=' CMakeCache.txt | cut -d= -f2-)
   OPENMP_LIBRARY=$(grep '^OpenMP_libomp_LIBRARY:FILEPATH=' CMakeCache.txt | cut -d= -f2-)
   if [ -n "$OPENMP_FLAGS" ] || [ -n "$OPENMP_LIBRARY" ]; then
      OPENMP_FOUND=yes
   fi
fi

echo "OPENMP_FOUND=$OPENMP_FOUND" >> ../configure.log

if [ "$WITH_OPENMP" == "yes" ] && [ "$OPENMP_FOUND" != "yes" ]; then
   echo "ERROR: OpenMP was requested with --with-openmp, but CMake could not find it." | tee -a ../configure.log
   if [ $ARCH == 'Darwin' ]; then
      echo "       Try installing libomp with: brew install libomp" | tee -a ../configure.log
   fi
   exit 1
fi

if [ "$WITH_OPENMP" == "yes" ]; then
   echo "-- OpenMP requested and detected"
elif [ "$WITH_OPENMP" == "no" ]; then
   echo "-- OpenMP explicitly disabled"
elif [ "$OPENMP_FOUND" == "yes" ]; then
   echo "-- OpenMP detected"
else
   echo "-- OpenMP not detected"
fi

echo "-- Build type: $BUILD_TYPE"

if [ $ARCH == 'Windoze' ]; then
   echo "-- Ensure release build is activated and static openbabl"
   echo "-- Run $MINGW_ROOT/bin/mingw32-make.exe inside the build directory"
fi

if [ $ARCH == 'Linux' ]; then
   echo "-- Ensure release build is activated and static openbabl"
   echo "-- May have to manually edit build/CMakeFiles/IQmol.dir/link.txt to fix linking:"
   echo "   Replace /path/to/libm.a with -lm"
fi

exit 0
